{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/validate-skill-frontmatter.sh\"",
            "timeout": 15,
            "statusMessage": "SKILL.mdのfrontmatterを検証中..."
          }
        ]
      }
    ]
  }
}
